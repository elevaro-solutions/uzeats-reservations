# API
PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/reservations
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Auth providers
# API verifies Google ID tokens with GOOGLE_CLIENT_ID.
# Web GIS button needs the same value as NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Maps / Places address autocomplete (web diner search + dashboard restaurant
# address forms). Enable Maps JavaScript API + Places API on the key. When
# empty or invalid, forms fall back to plain inputs automatically.
# Also set it in apps/web/.env.local and apps/dashboard/.env.local.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
# Dev mode: skip real Twilio and accept OTP 123456
AUTH_DEV_OTP=true

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# DigitalOcean Spaces
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=reservations
DO_SPACES_CDN=

# Notifications
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=Tablevera <noreply@tablevera.online>
TELEGRAM_BOT_TOKEN=
# Public API base URL (no trailing slash). Required in production for Telegram webhooks.
# Example: https://api.tablevera.online
API_PUBLIC_URL=
# Optional secret sent to Telegram when registering the webhook (recommended in production).
TELEGRAM_WEBHOOK_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@reservations.local

# Clients
NEXT_PUBLIC_API_URL=http://localhost:4000/graphql
NEXT_PUBLIC_WS_URL=ws://localhost:4000/graphql
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001
# Color palette: 1 = Forest & Gold (default), 2 = Terracotta & Amber
NEXT_PUBLIC_COLOR_PALETTE=1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_API_URL=http://localhost:4000/graphql
EXPO_PUBLIC_COLOR_PALETTE=1
